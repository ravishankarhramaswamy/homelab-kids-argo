{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "moodle": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "registry": { "type": "string" },
            "repository": { "type": "string" },
            "tag": { "type": "string" }
          }
        },
        "fullnameOverride": { "type": "string" },
        "existingSecret": { "type": "string" },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string" }
          }
        },
        "mariadb": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "auth": {
              "type": "object",
              "properties": {
                "existingSecret": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "name": { "type": "string" },
        "namespace": { "type": "string" }
      }
    }
  }
}
