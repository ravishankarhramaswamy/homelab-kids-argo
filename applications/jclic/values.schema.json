{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {"type": "integer", "minimum": 1},
    "fullnameOverride": {"type": "string"},
    "image": {
      "type": "object",
      "properties": {
        "repository": {"type": "string"},
        "tag": {"type": "string"},
        "pullPolicy": {"type": "string"}
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {"type": "string"},
        "port": {"type": "integer"}
      }
    },
    "content": {
      "type": "object",
      "properties": {
        "title": {"type": "string"},
        "subtitle": {"type": "string"},
        "jclicScriptUrl": {"type": "string"},
        "jclicCssUrl": {"type": "string"},
        "projectUrl": {"type": "string"}
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "size": {"type": "string"},
        "storageClass": {"type": "string"}
      }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "name": {"type": "string"},
        "namespace": {"type": "string"},
        "sectionName": {"type": "string"},
        "host": {"type": "string"},
        "serviceName": {"type": "string"},
        "servicePort": {"type": "integer"}
      }
    }
  }
}
