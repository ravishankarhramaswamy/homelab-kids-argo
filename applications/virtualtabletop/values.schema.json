{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "fullnameOverride": { "type": "string" },
    "service": {
      "type": "object",
      "properties": {
        "port": { "type": "integer" }
      }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "name": { "type": "string" },
        "namespace": { "type": "string" }
      }
    },
    "oauth2Proxy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "oidc": {
          "type": "object",
          "properties": {
            "issuerURL": { "type": "string" },
            "clientID": { "type": "string" },
            "existingSecret": { "type": "string" }
          }
        },
        "tls": {
          "type": "object",
          "properties": {
            "insecureSkipVerify": { "type": "boolean" }
          }
        }
      }
    }
  }
}
